from ultralytics import YOLO
import cv2
import time

model = YOLO('yolov8n.pt')

cam = cv2.VideoCapture(0) # Open the video file

if not cam.isOpened():	#make sure cam is open
	print("error")
else:
	print("success")


ret, frame = cam.read() # Read the first frame to confirm reading

if ret:
	cv2.imshow("cap frame", frame)
	cv2.waitKey(0)
else:
	print("cannot capture frame")

